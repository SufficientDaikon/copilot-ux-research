{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "./scripts/detect-project-brief.sh",
        "windows": "powershell -ExecutionPolicy Bypass -File scripts\\detect-project-brief.ps1",
        "timeout": 10
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "./scripts/on-research-complete.sh",
        "windows": "powershell -ExecutionPolicy Bypass -File scripts\\on-research-complete.ps1",
        "timeout": 10
      }
    ]
  }
}
